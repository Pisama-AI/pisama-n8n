# Pisama for n8n — dashboard configuration. Copy to .env.local and adjust.
# All NEXT_PUBLIC_* values are inlined at build time.

# --- Self-hosted mode (default) ---
# Where the pisama-n8n server is reachable from the browser.
NEXT_PUBLIC_API_BASE=http://localhost:8400
# Optional bearer key for the server (POSTs are bearer-gated). Usually set in
# the browser via Settings/localStorage instead.
# NEXT_PUBLIC_API_KEY=

# --- Feature flags (all default OFF) ---
# Auto-apply a generated fix to your LIVE n8n workflow. Fix *suggestions* are
# always shown; this only enables the one-click apply + rollback write path.
# Leave off until you trust fix quality on your workflows.
NEXT_PUBLIC_HEALING_APPLY=0
# Show the paid "Upgrade to Pro" / Stripe checkout CTA (SaaS mode). Off until
# you're charging real money.
NEXT_PUBLIC_BILLING=0
# Your n8n base URL, so detection detail can link out to the executions view.
# Self-host only; unset → no link is rendered.
# NEXT_PUBLIC_N8N_BASE_URL=https://your-team.app.n8n.cloud

# --- Marketing-only deploy (n8n.pisama.ai) ---
# No live demo: the dashboard routes (/overview, /detections, ...) redirect to
# the landing. Leave unset for a real dashboard (self-host or SaaS).
# NEXT_PUBLIC_READONLY=1

# --- Hosted SaaS mode (app.n8n.pisama.ai) ---
# NEXT_PUBLIC_SAAS=1
# NEXTAUTH_URL=http://localhost:3300
# NEXTAUTH_SECRET=
# SAAS_API_URL=http://localhost:8500
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
