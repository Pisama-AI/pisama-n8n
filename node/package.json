{
  "name": "n8n-nodes-pisama",
  "version": "0.3.0",
  "description": "n8n community node that forwards workflow executions to Pisama for failure detection and self-healing",
  "keywords": [
    "n8n-community-node-package",
    "pisama",
    "observability",
    "failure-detection",
    "ai-agents"
  ],
  "license": "MIT",
  "homepage": "https://pisama.ai",
  "author": {
    "name": "Pisama",
    "email": "support@pisama.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pisama-AI/pisama-n8n.git",
    "directory": "node"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PisamaApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pisama/Pisama.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}