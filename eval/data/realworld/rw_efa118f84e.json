 to suit your environment (or set it to \"manual\" for testing).\n- Connect your actual logic after the verification step.\n", "height": 580, "width": 720, "color": 1}, "typeVersion": 1}], "connections": {"hash matches": {"main": [[{"node": "200", "type": "main", "index": 0}, {"node": "Add nodes for processing", "type": "main", "index": 0}], [{"node": "403", "type": "main", "index": 0}]]}, "Calculate sha256": {"main": [[{"node": "hash matches", "type": "main", "index": 0}]]}, "Seatable Webhook": {"main": [[{"node": "Calculate sha256", "type": "main", "index": 0}]]}}, "settings": {"executionOrder": "v1"}, "nodeGroups": []}, "customData": {}, "_source": "/tmp/n8n_corpus/DragonJAR_n8n-workflows-esp/workflows/03322-Validate-Seatable-webhooks-with-HMAC-SHA256-authentication.json"}